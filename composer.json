{
  "name": "empik/marketplace-sdk",
  "description": "PHP client library for Empik Marketplace orders integration",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "symfony/http-client": "^6.4 || ^7.0",
    "symfony/mime": "^6.4 || ^7.0",
    "psr/log": "^1.1 || ^2.0 || ^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "symfony/http-client-mock": "^6.4 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "Empik\\Marketplace\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Empik\\Marketplace\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
